# Infrared reverse proxy (generic / clean-install form).
#
# Caddy routes by Host to the multi-tenant app and serves each core's images as
# static files. TLS + WAF terminate upstream at the ALB, so this is HTTP-only.
#
# The real EC2 box keeps its own copy (real hostnames + image dirs) as a
# git-ignored Caddyfile.ec2 mounted by docker-compose.ec2.yml — see EC2.md.

{
	auto_https off
	servers {
		trusted_proxies static private_ranges
	}
}

# Per-core block:  import infrared <url-image-prefix> <subdir-under-/srv/images>
(infrared) {
	handle_path {args[0]}/* {
		root * /srv/images/{args[1]}
		file_server
	}
	reverse_proxy web:8000
}

http://ggm.johnblowe.com {
	import infrared /ggm-images ggm
}
http://marc.johnblowe.com {
	import infrared /images marc
}
http://mmap.johnblowe.com {
	import infrared /mmap-images mmap
}
http://mmap-sites.johnblowe.com {
	import infrared /mmap-images mmap-sites
}
http://mmap-artifacts.johnblowe.com {
	import infrared /mmap-qdrive mmap-artifacts
}
http://tap.johnblowe.com {
	import infrared /images tap
}
http://tbdb.johnblowe.com {
	reverse_proxy web:8000
}

# Unmatched hosts (e.g. ALB health checks by IP) → default core.
:80 {
	reverse_proxy web:8000
}
